<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Rizz Live — Policy Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@400;500;700;800&family=Hind+Siliguri:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
  --g: #00C87A;
  --gd: #007A4A;
  --gdark: #003D24;
  --gl: rgba(0,200,122,0.12);
  --r: #FF3D5A;
  --rl: rgba(255,61,90,0.1);
  --gold: #FFB800;
  --goldl: rgba(255,184,0,0.1);
  --bg: #0A0F0D;
  --bg2: #0F1610;
  --card: #111A14;
  --card2: #162019;
  --border: rgba(0,200,122,0.15);
  --border2: rgba(255,255,255,0.07);
  --text: #E8F5EE;
  --muted: #7A9E8A;
  --sh: 0 4px 24px rgba(0,0,0,0.4);
  --sh2: 0 12px 40px rgba(0,0,0,0.6);
  --rad: 20px;
  --font-en: 'Cabinet Grotesk', sans-serif;
  --font-bn: 'Hind Siliguri', sans-serif;
  --font-display: 'Cabinet Grotesk', sans-serif;
  --font-display-bn: 'Noto Serif Bengali', serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:16px;-webkit-text-size-adjust:100%;scroll-behavior:smooth;}
body{background:var(--bg);font-family:var(--font-en);color:var(--text);line-height:1.6;min-height:100vh;overflow-x:hidden;}
body.bn{font-family:var(--font-bn);}

/* ── BG GRID ── */
body::after{
  content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(0,200,122,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,122,0.03) 1px,transparent 1px);
  background-size:50px 50px;pointer-events:none;z-index:0;
}

/* ── LANG SWITCHER ── */
.lang-wrap{position:fixed;top:12px;right:12px;z-index:9999;}
.lang-btn{
  display:flex;align-items:center;gap:6px;
  background:rgba(15,22,16,0.9);
  border:1px solid var(--border);
  border-radius:30px;padding:7px 14px;
  cursor:pointer;font-size:12px;font-weight:700;
  color:var(--text);backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  box-shadow:0 4px 20px rgba(0,0,0,0.5);
  transition:all 0.2s;-webkit-tap-highlight-color:transparent;
  font-family:var(--font-en);letter-spacing:0.5px;
}
.lang-btn:active{transform:scale(0.95);}
.lang-btn .flag{font-size:15px;}
.lang-chevron{width:14px;height:14px;opacity:0.5;transition:transform 0.25s;}
.lang-chevron svg{width:14px;height:14px;stroke:var(--text);stroke-width:2.5;fill:none;display:block;}
.lang-wrap.open .lang-chevron{transform:rotate(180deg);}

.lang-dd{
  position:absolute;top:calc(100% + 8px);right:0;
  background:rgba(15,22,16,0.97);
  border:1px solid var(--border);border-radius:16px;
  overflow:hidden;min-width:170px;
  box-shadow:0 16px 50px rgba(0,0,0,0.7);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  opacity:0;transform:translateY(-10px) scale(0.96);
  pointer-events:none;
  transition:all 0.22s cubic-bezier(0.34,1.5,0.64,1);
}
.lang-wrap.open .lang-dd{opacity:1;transform:translateY(0) scale(1);pointer-events:all;}
.lang-opt{
  display:flex;align-items:center;gap:12px;padding:13px 16px;
  cursor:pointer;transition:background 0.15s;
  border-bottom:1px solid var(--border2);
  -webkit-tap-highlight-color:transparent;
}
.lang-opt:last-child{border-bottom:none;}
.lang-opt:active,.lang-opt:hover{background:var(--gl);}
.lang-opt-flag{font-size:22px;}
.lang-opt-name{font-size:13px;font-weight:700;color:var(--text);font-family:var(--font-en);}
.lang-opt-sub{font-size:10px;color:var(--muted);margin-top:1px;}
.lang-opt-check{
  margin-left:auto;width:20px;height:20px;border-radius:50%;
  background:var(--g);display:flex;align-items:center;justify-content:center;
  opacity:0;transition:opacity 0.2s;flex-shrink:0;
}
.lang-opt-check svg{width:10px;height:10px;stroke:#000;stroke-width:3;fill:none;}
.lang-opt.active .lang-opt-check{opacity:1;}

/* ── TOPBAR ── */
.topbar{
  position:relative;z-index:10;
  background:rgba(5,10,7,0.95);
  height:42px;display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;border-bottom:1px solid var(--border2);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
}
.topbar::after{
  content:'';position:absolute;left:0;bottom:0;width:100%;height:2px;
  background:linear-gradient(90deg,var(--r),var(--gold),var(--g),var(--r));
  background-size:300%;animation:bar-slide 4s linear infinite;
}
@keyframes bar-slide{0%{background-position:0%}100%{background-position:300%}}
.tb-left{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--muted);font-family:var(--font-en);}
body.bn .tb-left{font-family:var(--font-bn);}
.tb-dot{width:6px;height:6px;border-radius:50%;background:var(--r);animation:dot-pulse 2s ease infinite;flex-shrink:0;}
@keyframes dot-pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(255,61,90,0.5)}50%{opacity:0.6;box-shadow:0 0 0 5px rgba(255,61,90,0)}}
.tb-live{
  background:var(--r);color:#fff;font-size:9px;font-weight:800;
  padding:3px 10px;border-radius:20px;letter-spacing:1.5px;
  animation:badge-glow 2.5s ease infinite;font-family:var(--font-en)!important;
}
@keyframes badge-glow{0%,100%{box-shadow:0 0 0 0 rgba(255,61,90,0.6)}50%{box-shadow:0 0 10px 4px rgba(255,61,90,0)}}

/* ── HERO ── */
header{
  position:relative;z-index:5;
  padding:20px 20px 40px;overflow:hidden;
  background:linear-gradient(165deg,#020D07 0%,#041808 30%,#062010 60%,#041408 100%);
}
.hero-orb{position:absolute;border-radius:50%;filter:blur(60px);pointer-events:none;}
.ho1{width:280px;height:280px;top:-80px;right:-80px;background:radial-gradient(circle,rgba(0,200,122,0.2),transparent 70%);animation:orb1 8s ease-in-out infinite;}
.ho2{width:200px;height:200px;bottom:-50px;left:-50px;background:radial-gradient(circle,rgba(255,61,90,0.15),transparent 70%);animation:orb2 10s ease-in-out infinite;}
.ho3{width:150px;height:150px;top:50%;left:60%;background:radial-gradient(circle,rgba(255,184,0,0.1),transparent 70%);animation:orb1 12s ease-in-out infinite reverse;}
@keyframes orb1{0%,100%{transform:translate(0,0)}50%{transform:translate(-20px,25px)}}
@keyframes orb2{0%,100%{transform:translate(0,0)}50%{transform:translate(25px,-20px)}}

/* Decorative circles */
.deco{position:absolute;border-radius:50%;pointer-events:none;}
.deco1{width:220px;height:220px;top:-60px;right:-60px;border:1px solid rgba(0,200,122,0.1);animation:spin 30s linear infinite;}
.deco2{width:150px;height:150px;top:-20px;right:-20px;border:1px dashed rgba(0,200,122,0.07);animation:spin 20s linear infinite reverse;}
@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}

.hero-inner{position:relative;z-index:2;padding-top:15px;}

.hero-chip{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,200,122,0.08);border:1px solid rgba(0,200,122,0.2);
  border-radius:30px;padding:5px 14px;
  font-size:11px;color:rgba(255,255,255,0.6);margin-bottom:22px;
  font-family:var(--font-en);letter-spacing:0.3px;
  animation:fadeUp 0.5s ease 0.1s both;
}
body.bn .hero-chip{font-family:var(--font-bn);}

.hero-brand{display:flex;align-items:center;gap:16px;margin-bottom:20px;animation:fadeUp 0.5s ease 0.2s both;}
.logo-box{
  width:68px;height:68px;
  background:linear-gradient(135deg,#1a3028,#0d1f16);
  border:1px solid rgba(0,200,122,0.25);
  border-radius:20px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 8px 30px rgba(0,0,0,0.5),0 0 0 1px rgba(0,200,122,0.1);
  flex-shrink:0;animation:logoFloat 5s ease-in-out infinite 1s;
}
@keyframes logoFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.logo-box svg{width:40px;height:40px;}
.brand-title{
  font-family:var(--font-display);font-size:38px;font-weight:800;
  color:#fff;line-height:1;letter-spacing:-1px;
}
body.bn .brand-title{font-family:var(--font-display-bn);font-size:32px;}
.brand-title em{color:var(--gold);font-style:italic;}
.brand-sub{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:5px;font-family:var(--font-en);}

.hero-desc{
  font-size:13px;color:rgba(255,255,255,0.5);
  line-height:1.8;max-width:320px;margin-bottom:26px;
  animation:fadeUp 0.5s ease 0.3s both;
}
body.bn .hero-desc{font-family:var(--font-bn);}

.hero-stats{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  gap:10px;margin-bottom:22px;
  animation:fadeUp 0.5s ease 0.4s both;
}
.hstat{
  background:rgba(0,200,122,0.06);
  border:1px solid rgba(0,200,122,0.15);
  border-radius:16px;padding:14px 8px;text-align:center;
  position:relative;overflow:hidden;
}
.hstat::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(0,200,122,0.3),transparent);
}
.hstat-val{
  font-family:var(--font-display);font-size:22px;font-weight:800;
  color:var(--gold);line-height:1;
}
body.bn .hstat-val{font-family:var(--font-display-bn);}
.hstat-lbl{font-size:10px;color:var(--muted);margin-top:4px;letter-spacing:0.5px;font-family:var(--font-en);}

.hero-tags{display:flex;flex-wrap:wrap;gap:8px;animation:fadeUp 0.5s ease 0.5s both;}
.htag{
  display:flex;align-items:center;gap:6px;
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
  border-radius:20px;padding:5px 13px;
  font-size:11px;color:rgba(255,255,255,0.55);
  font-family:var(--font-en);
}
body.bn .htag{font-family:var(--font-bn);}
.htag-dot{width:5px;height:5px;border-radius:50%;background:var(--g);flex-shrink:0;}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* WAVE */
.wave{position:relative;z-index:4;line-height:0;margin-top:-1px;}
.wave svg{width:100%;display:block;}

/* ── CONTAINER ── */
.container{position:relative;z-index:5;max-width:480px;margin:0 auto;padding:0 14px 100px;}

/* ── SECTION LABEL ── */
.sec-lbl{
  display:flex;align-items:center;gap:10px;
  font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--g);padding:26px 2px 14px;font-family:var(--font-en);
}
body.bn .sec-lbl{font-family:var(--font-bn);letter-spacing:0.5px;}
.sec-lbl::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent);}
.sec-icon{
  width:26px;height:26px;border-radius:7px;
  background:var(--gl);display:flex;align-items:center;justify-content:center;
  font-size:13px;flex-shrink:0;
}

/* ── MENU CARDS ── */
.menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:4px;}

.mcard{
  position:relative;
  background:var(--card);
  border-radius:var(--rad);
  padding:22px 16px 18px;
  cursor:pointer;overflow:hidden;
  border:1px solid var(--border2);
  transition:transform 0.2s ease,box-shadow 0.2s ease,border-color 0.2s ease;
  -webkit-tap-highlight-color:transparent;
  user-select:none;
  box-shadow:var(--sh);
  /* NO opacity:0 — cards always visible */
}
.mcard:hover{transform:translateY(-3px);box-shadow:var(--sh2);border-color:var(--border);}
.mcard:active{transform:scale(0.97);}

/* Glow border on hover */
.mcard-glow{
  position:absolute;inset:-1px;border-radius:var(--rad);
  background:linear-gradient(135deg,var(--g),var(--gold),var(--r));
  background-size:300%;opacity:0;z-index:0;
  animation:glow-move 4s linear infinite;transition:opacity 0.3s;
}
@keyframes glow-move{0%{background-position:0%}100%{background-position:300%}}
.mcard-inner-bg{
  position:absolute;inset:1px;border-radius:calc(var(--rad) - 1px);
  background:var(--card);z-index:1;
}
.mcard:hover .mcard-glow{opacity:1;}

/* Shine sweep */
.mcard-shine{
  position:absolute;top:0;left:-150%;width:50%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.06),transparent);
  transform:skewX(-15deg);z-index:3;pointer-events:none;
}
.mcard:hover .mcard-shine{animation:shine-sweep 0.6s ease forwards;}
@keyframes shine-sweep{to{left:160%;}}

/* Ripple */
.ripple{position:absolute;border-radius:50%;background:rgba(0,200,122,0.15);transform:scale(0);animation:ripple-out 0.6s linear;pointer-events:none;z-index:2;}
@keyframes ripple-out{to{transform:scale(5);opacity:0;}}

.mcard-body{position:relative;z-index:4;}

.mcard-icon{
  width:56px;height:56px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;margin-bottom:18px;
  position:relative;overflow:hidden;
  box-shadow:0 4px 20px rgba(0,0,0,0.3);
}
.mcard-icon::after{
  content:'';position:absolute;inset:0;border-radius:16px;
  background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent 60%);
}
.i-green{background:linear-gradient(135deg,#00E890,#00875A);}
.i-red{background:linear-gradient(135deg,#FF7A90,#E0002A);}
.i-gold{background:linear-gradient(135deg,#FFD060,#C88000);}
.i-teal{background:linear-gradient(135deg,#40FFCC,#009F78);}

.mcard-badge{
  position:absolute;top:14px;right:14px;z-index:5;
  background:var(--r);color:#fff;
  font-size:8px;font-weight:800;padding:3px 9px;
  border-radius:20px;letter-spacing:1px;
  font-family:var(--font-en)!important;text-transform:uppercase;
  animation:badge-glow 2.5s ease infinite;
}

.mcard-title{
  font-size:16px;font-weight:800;color:var(--text);
  margin-bottom:6px;line-height:1.2;font-family:var(--font-display);
}
body.bn .mcard-title{font-family:var(--font-bn);}
.mcard-desc{font-size:11.5px;color:var(--muted);line-height:1.5;}
body.bn .mcard-desc{font-family:var(--font-bn);}

.mcard-foot{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:16px;padding-top:14px;
  border-top:1px solid var(--border2);
}
.mcard-tag{font-size:10px;font-weight:700;color:var(--g);letter-spacing:1px;text-transform:uppercase;font-family:var(--font-en);}
body.bn .mcard-tag{font-family:var(--font-bn);text-transform:none;letter-spacing:0;}
.mcard-arr{
  width:30px;height:30px;border-radius:9px;
  background:rgba(0,200,122,0.1);border:1px solid rgba(0,200,122,0.2);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;color:var(--g);transition:all 0.2s;
}
.mcard:active .mcard-arr,.mcard:hover .mcard-arr{background:var(--g);color:#000;transform:translateX(2px);}

/* ── BACK BTN ── */
.back-btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 20px;border:1px solid var(--border2);
  border-radius:30px;background:var(--card);
  cursor:pointer;font-size:13px;font-weight:600;
  color:var(--muted);margin:16px 0 8px;
  transition:all 0.2s;font-family:var(--font-en);
  -webkit-tap-highlight-color:transparent;
  box-shadow:var(--sh);
}
body.bn .back-btn{font-family:var(--font-bn);}
.back-btn:active{background:var(--gl);border-color:var(--g);color:var(--g);transform:scale(0.97);}

.page-title{
  font-family:var(--font-display);font-size:26px;font-weight:800;
  color:var(--text);margin:6px 0 22px;line-height:1.2;
  animation:fadeUp 0.4s ease both;
}
body.bn .page-title{font-family:var(--font-display-bn);font-size:22px;}

/* ── TABS ── */
.tab{display:none;}
.tab.active{display:block;animation:pageIn 0.3s ease;}
@keyframes pageIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── ACCORDION ── */
.acc{
  background:var(--card);border:1px solid var(--border2);
  border-radius:var(--rad);margin-bottom:10px;overflow:hidden;
  transition:border-color 0.25s,box-shadow 0.25s;
  box-shadow:var(--sh);
}
.acc.open{border-color:rgba(0,200,122,0.25);box-shadow:0 8px 40px rgba(0,200,122,0.08);}
.acc-head{
  display:flex;align-items:center;gap:12px;padding:16px;
  cursor:pointer;-webkit-tap-highlight-color:transparent;user-select:none;
}
.acc-head:active{background:rgba(0,200,122,0.05);}
.acc-num{
  width:42px;height:42px;border-radius:12px;
  background:rgba(0,200,122,0.08);border:1px solid rgba(0,200,122,0.15);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-display);font-size:15px;font-weight:800;color:var(--g);
  flex-shrink:0;transition:all 0.25s;
}
body.bn .acc-num{font-family:var(--font-display-bn);}
.acc.open .acc-num{background:var(--g);color:#000;border-color:var(--g);}
.acc-info{flex:1;min-width:0;}
.acc-title{font-size:15px;font-weight:700;color:var(--text);line-height:1.3;}
body.bn .acc-title{font-family:var(--font-bn);}
.acc-sub{font-size:11px;color:var(--muted);margin-top:2px;font-family:var(--font-en);}
.acc-tog{
  width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,0.05);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.3s;
}
.acc.open .acc-tog{background:var(--gl);transform:rotate(180deg);}
.acc-tog svg{width:16px;height:16px;stroke:var(--g);stroke-width:2.5;fill:none;}
.acc-body{max-height:0;overflow:hidden;transition:max-height 0.4s ease;}
.acc.open .acc-body{max-height:8000px;}
.acc-inner{padding:0 16px 20px;border-top:1px solid var(--border2);}

/* ── SUBLABEL ── */
.sub-lbl{
  font-size:10px;font-weight:700;letter-spacing:1.5px;
  text-transform:uppercase;color:var(--g);
  margin:18px 0 10px;display:flex;align-items:center;gap:8px;font-family:var(--font-en);
}
body.bn .sub-lbl{font-family:var(--font-bn);text-transform:none;letter-spacing:0;}
.sub-lbl::after{content:'';flex:1;height:1px;background:var(--border2);}

/* ── INFO BOX ── */
.ibox{border-radius:13px;padding:13px 15px;margin:10px 0;border-left:3px solid var(--g);background:var(--gl);}
.ibox.warn{border-left-color:var(--gold);background:var(--goldl);}
.ibox.danger{border-left-color:var(--r);background:var(--rl);}
.ibox.ok{border-left-color:var(--g);background:rgba(0,200,122,0.08);}
.ibox-lbl{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--g);margin-bottom:5px;font-family:var(--font-en);}
body.bn .ibox-lbl{font-family:var(--font-bn);text-transform:none;letter-spacing:0;}
.ibox.warn .ibox-lbl{color:var(--gold);}
.ibox.ok .ibox-lbl{color:var(--g);}
.ibox-txt{font-size:13px;color:var(--text);line-height:1.65;}
body.bn .ibox-txt{font-family:var(--font-bn);}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto;margin:10px 0;border-radius:14px;border:1px solid var(--border2);box-shadow:var(--sh);}
table{width:100%;border-collapse:collapse;min-width:220px;}
thead{background:rgba(0,200,122,0.07);}
th{padding:11px 13px;text-align:left;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--g);white-space:nowrap;font-family:var(--font-en);}
td{padding:11px 13px;border-bottom:1px solid var(--border2);font-size:13px;color:var(--text);transition:background 0.15s;}
body.bn td{font-family:var(--font-bn);}
tr:hover td{background:rgba(0,200,122,0.04);}
tr:last-child td{border-bottom:none;}
.tg{color:var(--g);font-weight:700;}
.tr{color:var(--r);font-weight:700;}
.tgold{color:var(--gold);font-weight:700;}
.tbold{font-weight:700;color:var(--text);}

/* ── BLIST ── */
.blist{list-style:none;margin:6px 0;}
.blist li{
  padding:9px 0 9px 24px;position:relative;
  font-size:13px;color:var(--text);line-height:1.6;
  border-bottom:1px solid rgba(255,255,255,0.04);
}
body.bn .blist li{font-family:var(--font-bn);}
.blist li:last-child{border-bottom:none;}
.blist li::before{
  content:'';position:absolute;left:0;top:17px;
  width:9px;height:9px;border-radius:50%;
  background:linear-gradient(135deg,var(--g),#009955);
}
.blist.danger li::before{background:linear-gradient(135deg,#FF9AA8,var(--r));}
.blist.ok li::before{background:linear-gradient(135deg,#80FFD0,var(--g));}

/* ── STAT ROW ── */
.stat-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0;}
.stat-card{
  background:rgba(0,200,122,0.07);border:1px solid rgba(0,200,122,0.15);
  border-radius:14px;padding:16px;text-align:center;position:relative;overflow:hidden;
}
.stat-card::before{content:'';position:absolute;top:-20px;right:-20px;width:70px;height:70px;border-radius:50%;background:rgba(0,200,122,0.08);}
.stat-val{font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--g);line-height:1;margin-bottom:4px;}
body.bn .stat-val{font-family:var(--font-display-bn);}
.stat-lbl{font-size:11px;color:var(--muted);font-family:var(--font-en);}
body.bn .stat-lbl{font-family:var(--font-bn);}

.wbadge{display:inline-block;background:rgba(0,200,122,0.1);border:1px solid rgba(0,200,122,0.2);color:var(--g);font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;}

/* ── CONTACT CARD ── */
.contact-card{
  display:flex;align-items:center;gap:14px;
  background:var(--card2);border:1px solid var(--border2);
  border-radius:16px;padding:14px;margin:10px 0;
  transition:all 0.2s;cursor:pointer;box-shadow:var(--sh);
}
.contact-card:active,.contact-card:hover{border-color:var(--border);background:rgba(0,200,122,0.06);}
.c-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.c-icon.wa{background:linear-gradient(135deg,#00E87A,#009950);}
.c-icon.em{background:linear-gradient(135deg,rgba(0,200,122,0.3),rgba(0,200,122,0.1));}
.c-icon.tm{background:linear-gradient(135deg,rgba(100,160,255,0.3),rgba(60,100,200,0.2));}
.c-lbl{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:2px;font-family:var(--font-en);}
body.bn .c-lbl{font-family:var(--font-bn);text-transform:none;letter-spacing:0;}
.c-val{font-size:13px;font-weight:600;color:var(--text);}
body.bn .c-val{font-family:var(--font-bn);}
.c-val a{color:var(--g);text-decoration:none;}

/* ── CTA ── */
.cta{
  display:flex;align-items:center;justify-content:center;gap:9px;
  width:100%;padding:16px 20px;border:none;border-radius:14px;
  font-size:14px;font-weight:700;font-family:var(--font-en);
  cursor:pointer;text-decoration:none;margin:14px 0;
  position:relative;overflow:hidden;
  -webkit-tap-highlight-color:transparent;
  transition:transform 0.18s,box-shadow 0.18s;
}
body.bn .cta{font-family:var(--font-bn);}
.cta::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);
  background-size:300%;animation:shine-btn 2.5s ease infinite;
}
@keyframes shine-btn{0%{background-position:-100%}100%{background-position:400%}}
.cta.green{background:linear-gradient(135deg,var(--g),var(--gd));color:#000;box-shadow:0 6px 25px rgba(0,200,122,0.4);}
.cta.wa{background:linear-gradient(135deg,#25D366,#128C3A);color:#fff;box-shadow:0 6px 25px rgba(37,211,102,0.4);}
.cta:active{transform:scale(0.97);box-shadow:none;}

/* ── FOOTER ── */
footer{
  background:var(--bg2);padding:40px 20px 32px;
  text-align:center;position:relative;overflow:hidden;
}
footer::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--r),var(--gold),var(--g),var(--r));
  background-size:300%;animation:bar-slide 4s linear infinite;
}
footer::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 50% 0%,rgba(0,200,122,0.08),transparent 60%);
}
.ft-flag{font-size:36px;display:block;margin-bottom:12px;animation:logoFloat 4s ease-in-out infinite;position:relative;z-index:1;}
.ft-logo{font-family:var(--font-display);font-size:26px;font-weight:800;color:#fff;position:relative;z-index:1;}
body.bn .ft-logo{font-family:var(--font-display-bn);}
.ft-logo em{color:var(--gold);font-style:italic;}
.ft-copy{font-size:11px;color:rgba(255,255,255,0.25);margin-top:10px;line-height:1.9;position:relative;z-index:1;font-family:var(--font-en);}
body.bn .ft-copy{font-family:var(--font-bn);}

/* ── MISC ── */
strong{font-weight:800;}
.gt{color:var(--g);font-weight:700;}
.rt{color:var(--r);font-weight:700;}
.got{color:var(--gold);font-weight:700;}
.muted-t{color:var(--muted);}

::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:rgba(0,200,122,0.3);border-radius:4px;}
</style>
</head>
