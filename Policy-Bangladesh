<script>
/* LANG */
let lang='en';
function toggleLang(){
  const w=document.getElementById('langWrap');
  w.classList.toggle('open');
  if(w.classList.contains('open')){
    setTimeout(()=>document.addEventListener('click',function oc(e){
      if(!e.target.closest('.lang-wrap')){w.classList.remove('open');}
      document.removeEventListener('click',oc);
    }),50);
  }
}
function setLang(l){
  lang=l;
  document.getElementById('langWrap').classList.remove('open');
  document.getElementById('langFlag').textContent=l==='en'?'🇬🇧':'🇧🇩';
  document.getElementById('langLbl').textContent=l==='en'?'EN':'বাং';
  document.getElementById('optEn').classList.toggle('active',l==='en');
  document.getElementById('optBn').classList.toggle('active',l==='bn');
  document.body.classList.toggle('bn',l==='bn');
  applyLang();
}
function applyLang(){
  document.querySelectorAll('.t[data-'+lang+']').forEach(el=>{
    el.innerHTML=el.getAttribute('data-'+lang);
  });
}

/* ACCORDION */
function toggleAcc(el){
  const wasOpen=el.classList.contains('open');
  el.classList.toggle('open');
  const pts=el.querySelector('.acc-tog svg polyline');
  if(pts)pts.setAttribute('points',el.classList.contains('open')?'18 15 12 9 6 15':'6 9 12 15 18 9');
}

/* NAVIGATE */
function go(id,card){
  if(card){
    const rip=document.createElement('span');
    rip.className='ripple';
    const s=Math.max(card.offsetWidth,card.offsetHeight)*1.8;
    rip.style.cssText=`width:${s}px;height:${s}px;left:${card.offsetWidth/2-s/2}px;top:${card.offsetHeight/2-s/2}px;`;
    card.appendChild(rip);
    setTimeout(()=>rip.remove(),650);
  }
  setTimeout(()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    const target=document.getElementById(id);
    target.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
    /* animate accordions */
    target.querySelectorAll('.acc').forEach((a,i)=>{
      a.style.animation='none';a.style.opacity='1';a.style.transform='none';
      void a.offsetWidth;
      a.style.animation='';
      a.style.opacity='0';a.style.transform='translateY(16px)';
      setTimeout(()=>{
        a.style.opacity='1';a.style.transform='translateY(0)';
        a.style.transition='opacity 0.35s ease, transform 0.35s ease';
      },i*70+50);
    });
    /* re-apply language */
    applyLang();
  },card?140:0);
}
</script>
